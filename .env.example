# =============================================================================
# Customer Intelligence Platform — Environment Variables
# Copy this file to `.env` and fill in real secrets before running.
# Never commit `.env` to source control (it is listed in .gitignore).
# =============================================================================

# --- PostgreSQL connection ---------------------------------------------------
# Hostname of the PostgreSQL service (service name on the Docker network).
POSTGRES_HOST=postgres
# Port PostgreSQL listens on inside the internal network.
POSTGRES_PORT=5432
# Superuser/application username for PostgreSQL.
POSTGRES_USER=cip_admin
# Superuser/application password for PostgreSQL. Change before running.
POSTGRES_PASSWORD=change_me
# Primary application database name.
POSTGRES_DB=cip

# --- Airflow -----------------------------------------------------------------
# Fernet key used by Airflow to encrypt connection credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=change_me
# Secret key for the Airflow webserver session/signing.
AIRFLOW_SECRET_KEY=change_me
# Password for the initial Airflow admin user created by airflow-init.
AIRFLOW_ADMIN_PASSWORD=change_me

# --- Application database URL -------------------------------------------------
# SQLAlchemy/psycopg-style connection string used by application services.
DATABASE_URL=postgresql://cip_admin:change_me@postgres:5432/cip
# Minimum size of the API PostgreSQL connection pool.
DB_POOL_MIN=5
# Maximum size of the API PostgreSQL connection pool.
DB_POOL_MAX=20

# --- MLflow ------------------------------------------------------------------
# Backend store URI (metadata) for MLflow — points at the mlflow database.
MLFLOW_BACKEND_STORE_URI=postgresql://cip_admin:change_me@postgres:5432/mlflow
# Tracking URI that clients use to reach the MLflow server.
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Metabase ----------------------------------------------------------------
# Password for the read-only PostgreSQL user Metabase uses to query marts.
METABASE_DB_PASSWORD=change_me
# Username for Metabase's own application database.
MB_DB_USER=metabase
# Password for Metabase's own application database.
MB_DB_PASS=change_me
# Database name for Metabase's own application database.
MB_DB_DBNAME=metabase
